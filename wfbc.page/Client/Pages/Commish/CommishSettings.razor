@page "/commish/settings"
@attribute [Authorize(Policy = Policies.IsCommish)]
@using WFBC.Shared.Models
@using WFBC.Client.Shared.Components.Buttons
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@inject AuthorizedClient AuthorizedClient

<div class="flex flex-col my-6 lg:mx-6 w-full md:w-2/3 lg:w-1/3">
    <h3 class="text-wfbc-blue-2 font-semibold mb-4">Commish Settings</h3>

    <div class="p-6 border rounded-xl shadow-sm space-y-4">
        <h4 class="text-wfbc-blue-2 font-medium">Rotowire Cookie</h4>
        <p class="text-xs text-gray-500">
            Paste your Rotowire session cookie here. Log in to rotowire.com, open DevTools (F12),
            go to Application → Cookies → www.rotowire.com, then copy all cookie values as a single string.
        </p>
        <textarea @bind="cookieValue" rows="5" placeholder="Paste cookie string here..."
                  class="w-full p-2 rounded-md bg-wfbc-grey-1 border-transparent focus:border-wfbc-blue-2 focus:bg-wfbc-white-1 text-sm font-mono resize-y"></textarea>

        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <p class="text-sm @(isError ? "text-red-500" : "text-green-600")">@statusMessage</p>
        }

        <div class="flex gap-2">
            <Button ButtonText="Save Cookie" OnClickFunction="@(async () => await SaveSettings())" MaxWidth="max-w-full" MarginPadding="px-4 py-2" />
            <Button ButtonText="Clear Cookie" OnClickFunction="@(async () => await ClearSettings())" MaxWidth="max-w-full" MarginPadding="px-4 py-2" />
        </div>
    </div>

    <div class="mt-4">
        <Button ButtonText="← Back to Commish" Href="/commish" MaxWidth="max-w-full" MarginPadding="px-4 py-2" />
    </div>
</div>

@code {
    private string cookieValue = string.Empty;
    private string statusMessage = string.Empty;
    private bool isError = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var s = await AuthorizedClient.Client.GetFromJsonAsync<WFBC.Shared.Models.CommishSettings>("/api/commishsettings");
            if (s?.RotowireCookie != null) cookieValue = s.RotowireCookie;
        }
        catch { statusMessage = "Could not load settings."; isError = true; }
    }

    private async Task SaveSettings()
    {
        try
        {
            var resp = await AuthorizedClient.Client.PostAsJsonAsync("/api/commishsettings", new WFBC.Shared.Models.CommishSettings { RotowireCookie = cookieValue });
            statusMessage = resp.IsSuccessStatusCode ? "Settings saved." : "Failed to save settings.";
            isError = !resp.IsSuccessStatusCode;
        }
        catch (Microsoft.AspNetCore.Components.WebAssembly.Authentication.AccessTokenNotAvailableException e) { e.Redirect(); }
        catch { statusMessage = "An error occurred."; isError = true; }
    }

    private async Task ClearSettings() { cookieValue = string.Empty; await SaveSettings(); }
}