@page "/commish/teams"
@attribute [Authorize(Policy = Policies.IsCommish)]
@inherits TeamsModel
@using WFBC.Client.Shared.Components.Buttons;

<div class="flex flex-col m-3 lg:m-6 max-w-full">
    <div class="flex flex-wrap items-center gap-2 p-4 mb-2 border rounded-xl shadow-sm">
        <Button ButtonText="Add Team" Href=@($"/commish/add_team/{selectedYear}") Role="button" AriaLabel="add team link" />
        <div class="flex items-center gap-2 ml-auto">
            <label class="text-sm text-wfbc-blue-2 font-medium">Year:</label>
            <select class="pl-2 h-8 rounded-md bg-wfbc-grey-1 border-transparent focus:border-wfbc-blue-2 focus:bg-wfbc-white-1 text-sm"
                    value="@selectedYear" @onchange="OnYearChanged">
                @foreach (var year in availableYears)
                {
                    <option value="@year">@year</option>
                }
            </select>
        </div>
    </div>

    <div class="p-6 border rounded-xl shadow-sm">
        <div class="-m-1.5 overflow-x-auto">
            <div class="p-1.5 min-w-full inline-block align-middle">
                <div class="overflow-hidden">
                    <table class="table-auto min-w-full divide-y divide-wfbc-blue-2">
                        <thead>
                            <tr>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-wfbc-black-1 uppercase">Team Name</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-wfbc-black-1 uppercase">Team ID</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-wfbc-black-1 uppercase">Manager</th>
                                <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-wfbc-black-1 uppercase">Options</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-wfbc-blue-2">
                            @foreach (var team in seasonTeams)
                            {
                                <tr>
                                    <td class="p-2 md:p-4 text-sm md:text-md">@team.TeamName</td>
                                    <td class="p-2 md:p-4 text-sm md:text-md">@team.TeamId</td>
                                    <td class="p-2 md:p-4 text-sm md:text-md">@team.Manager</td>
                                    <td class="p-2 md:p-4 text-sm md:text-md flex">
                                        <Button ButtonText="Edit" Href=@($"/commish/edit_team/{selectedYear}/{team.Id}") AriaLabel="edit team link" />
                                        <Button ButtonText="Delete" FunctionParameter="@team.Id" OnClickFunction=OpenDeleteModal AriaLabel="open delete team modal" />
                                    </td>
                                </tr>
                            }
                            @if (!seasonTeams.Any())
                            {
                                <tr><td colspan="4" class="p-4 text-sm text-center text-gray-500">No teams found for @selectedYear</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<Modal ModalId="delete-team-modal" Hidden="@Hidden" CloseModal=CloseModal>
    <h3 class="mb-5 text-lg font-normal text-wfbc-black-1">Are you sure you want to delete this team?</h3>
    <h3 class="mb-5 text-lg font-normal text-wfbc-black-1">@($"Team: {seasonTeam.TeamName}")</h3>
    <Button ButtonText="Yes, I'm sure" OnClickFunction=Delete FunctionParameter="@seasonTeam.Id" Hover="hover:bg-wfbc-red-1" />
    <Button ButtonText="No, cancel" OnClickFunction=CloseModal />
</Modal>

@code {
    public string Hidden { get; set; }
    protected override async Task OnInitializedAsync() { Hidden = "hidden"; await base.OnInitializedAsync(); }
    public void OpenDeleteModal(string id) { Hidden = ""; DeleteConfirm(id); }
    public void CloseModal() { Hidden = "hidden"; }
    public async Task Delete(string id) { await DeleteSeasonTeam(id); CloseModal(); }
}