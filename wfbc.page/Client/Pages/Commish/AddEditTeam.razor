@page "/commish/add_team/{year}"
@page "/commish/edit_team/{year}/{teamId}"
@inherits AddEditTeamModel
@using WFBC.Client.Shared.Components.Buttons

<EditForm class="flex flex-col my-6 lg:mx-6 w-full md:w-1/2 lg:w-1/4" Model="@seasonTeam" OnValidSubmit="SaveTeam">
    <DataAnnotationsValidator />

    <h3 class="text-wfbc-blue-2 font-semibold mb-4">@Title Team (@selectedYear)</h3>

    <label class="block mb-3">
        <span class="text-wfbc-blue-2">Team Name</span>
        <InputText @bind-Value="seasonTeam.TeamName" class="mt-1 pl-2 block w-full rounded-md bg-wfbc-grey-1 border-transparent focus:border-wfbc-blue-2 focus:bg-wfbc-white-1 focus ring-0" />
    </label>

    <label class="block mb-3">
        <span class="text-wfbc-blue-2">Team ID (Rotowire)</span>
        <InputText @bind-Value="seasonTeam.TeamId" class="mt-1 pl-2 block w-full rounded-md bg-wfbc-grey-1 border-transparent focus:border-wfbc-blue-2 focus:bg-wfbc-white-1 focus ring-0" />
    </label>

    <label class="block mb-3">
        <span class="text-wfbc-blue-2">Manager</span>
        <InputSelect @bind-Value="seasonTeam.ManagerId" class="mt-1 pl-2 h-8 block w-full rounded-md bg-wfbc-grey-1 border-transparent focus:border-wfbc-blue-2 focus:bg-wfbc-white-1 focus ring-0">
            <option value="">-- None --</option>
            @foreach (var mgr in managers)
            {
                <option value="@mgr.Id">@mgr.FirstName @mgr.LastName</option>
            }
        </InputSelect>
    </label>

    <Button OnClickFunction="@(async () => await SaveTeam())" ButtonText="Save Team" ButtonType="submit" MaxWidth="max-w-full" MarginPadding="mx-2 mt-4 px-4 py-2" />
    <Button ButtonText="Cancel" Href="/commish/teams" MaxWidth="max-w-full" MarginPadding="mx-2 mt-2 px-4 py-2" />
</EditForm>

@code { }