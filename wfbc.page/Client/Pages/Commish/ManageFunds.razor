@page "/commish/funds"
@attribute [Authorize(Policy = Policies.IsCommish)]
@using WFBC.Shared.Models
@using WFBC.Client.Shared.Components.Buttons
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@inject AuthorizedClient AuthorizedClient
@inject PublicClient PublicClient

<div class="flex flex-col my-6 lg:mx-6 w-full md:w-2/3 lg:w-1/2">
    <h3 class="text-wfbc-blue-2 font-semibold mb-4">The Funds</h3>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="mb-4 p-3 rounded-md @(isError ? "bg-red-50 text-red-700" : "bg-green-50 text-green-700") text-sm">
            @statusMessage
        </div>
    }

    @* Add Data Point Form *@
    <div class="p-6 border rounded-xl shadow-sm space-y-4 mb-6">
        <h4 class="text-wfbc-blue-2 font-medium">Add Data Point</h4>

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Date</label>
                <input type="date" value="@DateStr"
                       @onchange="e => OnDateChanged(e.Value?.ToString())"
                       class="w-full p-2 rounded-md bg-wfbc-grey-1 border border-gray-300 text-sm" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Amount ($)</label>
                <input type="number" step="0.01" @bind="amount"
                       class="w-full p-2 rounded-md bg-wfbc-grey-1 border border-gray-300 text-sm" />
            </div>
        </div>

        <div class="flex gap-2">
            <Button ButtonText="Add Data Point" OnClickFunction="@(async () => await AddDataPoint())" MaxWidth="max-w-full" MarginPadding="px-4 py-2" />
        </div>
    </div>

    @* Existing Data Points *@
    <div class="border rounded-xl shadow-sm overflow-hidden mb-4">
        <table class="w-full text-sm">
            <thead class="bg-wfbc-blue-1 text-white">
                <tr>
                    <th class="p-3 text-left">Date</th>
                    <th class="p-3 text-left">Amount</th>
                    <th class="p-3 text-left">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (dataPoints == null || !dataPoints.Any())
                {
                    <tr><td colspan="3" class="p-4 text-center text-gray-400">No data points yet.</td></tr>
                }
                else
                {
                    @foreach (var dp in dataPoints.OrderByDescending(x => x.Date))
                    {
                        <tr class="border-t hover:bg-gray-50">
                            <td class="p-3 font-medium">@dp.Date.ToString("MM/dd/yyyy")</td>
                            <td class="p-3">$@dp.Amount.ToString("N2")</td>
                            <td class="p-3">
                                <button @onclick="() => DeleteConfirm(dp)" class="text-red-500 hover:underline text-xs">Delete</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (confirmDelete != null)
    {
        <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700 mb-4">
            <p class="mb-2">Delete data point for <strong>@confirmDelete.Date.ToString("MM/dd/yyyy")</strong> ($@confirmDelete.Amount.ToString("N2"))? This cannot be undone.</p>
            <div class="flex gap-2">
                <button @onclick="@(async () => await DeleteDataPoint())" class="px-3 py-1 rounded text-xs" style="background-color: #dc2626; color: white;">Confirm Delete</button>
                <button @onclick="() => confirmDelete = null" class="px-3 py-1 rounded text-xs" style="background-color: #e5e7eb; color: #374151;">Cancel</button>
            </div>
        </div>
    }

    <div class="mt-2">
        <Button ButtonText="← Back to Commish" Href="/commish" MaxWidth="max-w-full" MarginPadding="px-4 py-2" />
    </div>
</div>

@code {
    private List<FundsDataPoint> dataPoints = new();
    private DateTime selectedDate = DateTime.Today;
    private decimal amount = 0;
    private string statusMessage = string.Empty;
    private bool isError = false;
    private FundsDataPoint? confirmDelete = null;
    private string currentYear = DateTime.Now.Year.ToString();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataPoints();
    }

    private async Task LoadDataPoints()
    {
        try
        {
            var response = await PublicClient.Client.GetFromJsonAsync<FundsResponse>($"/api/funds/{currentYear}");
            dataPoints = response?.DataPoints ?? new();
        }
        catch { statusMessage = "Could not load funds data."; isError = true; }
    }

    private string DateStr => selectedDate.ToString("yyyy-MM-dd");
    private void OnDateChanged(string? val) { if (DateTime.TryParse(val, out var d)) selectedDate = d; }

    private async Task AddDataPoint()
    {
        try
        {
            var dataPoint = new FundsDataPoint
            {
                Date = selectedDate,
                Amount = amount
            };

            var resp = await AuthorizedClient.Client.PostAsJsonAsync($"/api/funds/{currentYear}", dataPoint);

            if (resp.IsSuccessStatusCode)
            {
                statusMessage = $"Data point added for {selectedDate:MM/dd/yyyy}.";
                isError = false;
                amount = 0;
                await LoadDataPoints();
            }
            else
            {
                statusMessage = "Failed to add data point.";
                isError = true;
            }
        }
        catch (AccessTokenNotAvailableException e) { e.Redirect(); }
        catch { statusMessage = "An error occurred."; isError = true; }
    }

    private void DeleteConfirm(FundsDataPoint dp) => confirmDelete = dp;

    private async Task DeleteDataPoint()
    {
        if (confirmDelete == null) return;
        try
        {
            var resp = await AuthorizedClient.Client.DeleteAsync($"/api/funds/{currentYear}/{confirmDelete.Id}");
            statusMessage = resp.IsSuccessStatusCode ? "Data point deleted." : "Failed to delete.";
            isError = !resp.IsSuccessStatusCode;
            confirmDelete = null;
            await LoadDataPoints();
        }
        catch (AccessTokenNotAvailableException e) { e.Redirect(); }
        catch { statusMessage = "An error occurred."; isError = true; }
    }
}