@using WFBC.Shared.Models

<div class="border-2 border-wfbc-blue-2 rounded-xl bg-wfbc-white-1 overflow-hidden w-full max-w-full">
    <!-- Header strip - matches StandingsTable -->
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center p-2 sm:p-3 bg-wfbc-grey-1 border-b border-wfbc-grey-2 gap-2 sm:gap-0">
        <div>
            <h2 class="text-base sm:text-lg font-semibold text-wfbc-blue-2">Advanced Stats</h2>
            @if (!string.IsNullOrEmpty(LastUpdatedText))
            {
                <p class="text-[10px] sm:text-xs text-gray-500">Updated: @LastUpdatedText</p>
            }
        </div>
    </div>

    @if (Standings?.Count > 0 && Standings.Any(s => s.Advanced != null))
    {
        <!-- Mobile carousel (below md) -->
        <div class="md:hidden bg-wfbc-blue-2">
            <!-- Card indicator + nav arrows -->
            <div class="flex items-center justify-between px-3 py-2">
                <button class="w-8 h-8 flex items-center justify-center rounded-full bg-wfbc-blue-1 text-wfbc-white-1 text-lg font-bold disabled:opacity-30 transition-opacity"
                        disabled="@(currentCardIndex == 0)"
                        @onclick="PreviousCard">
                    ‹
                </button>
                <span class="text-wfbc-white-1 text-sm font-semibold tabular-nums">
                    @(currentCardIndex + 1) / @categories.Count
                </span>
                <button class="w-8 h-8 flex items-center justify-center rounded-full bg-wfbc-blue-1 text-wfbc-white-1 text-lg font-bold disabled:opacity-30 transition-opacity"
                        disabled="@(currentCardIndex == categories.Count - 1)"
                        @onclick="NextCard">
                    ›
                </button>
            </div>

            <!-- Swipeable card container -->
            <div class="overflow-hidden px-3 pb-3 w-full max-w-[100vw]"
                 @ontouchstart="HandleTouchStart"
                 @ontouchmove="HandleTouchMove"
                 @ontouchend="HandleTouchEnd"
                 @ontouchstart:preventDefault="false"
                 @ontouchmove:preventDefault="@isSwiping"
                 @ontouchend:preventDefault="false">
                <div class="flex transition-transform duration-300 ease-out"
                     style="transform: translateX(calc(-@(currentCardIndex)00% + @(swipeOffsetPx)px - @(currentCardIndex * 12)px)); gap: 12px;">
                    @foreach (var category in categories)
                    {
                        var ranked = RankForCategory(category);
                        <div class="min-w-full max-w-full flex-shrink-0">
                            @RenderCard(category, ranked)
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Desktop grid (md and above) -->
        <div class="hidden md:grid grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4 gap-3 sm:gap-4 p-3 sm:p-4 bg-wfbc-blue-2">
            @foreach (var category in categories)
            {
                var ranked = RankForCategory(category);
                @RenderCard(category, ranked)
            }
        </div>
    }
    else
    {
        <div class="p-4 sm:p-6 text-center text-sm text-wfbc-blue-2 bg-wfbc-white-1">
            No advanced stats available for this year yet. Rebuild standings to populate advanced metrics.
        </div>
    }
</div>

@code {
    [Parameter] public List<Standings> Standings { get; set; } = new();
    [Parameter] public string? LastUpdatedText { get; set; }

    // Mobile carousel state
    private int currentCardIndex = 0;
    private double touchStartX = 0;
    private double touchStartY = 0;
    private double touchCurrentX = 0;
    private double swipeOffsetPx = 0;
    private bool isSwiping = false;
    private bool swipeDirectionDetermined = false;

    private void PreviousCard()
    {
        if (currentCardIndex > 0)
        {
            currentCardIndex--;
        }
    }

    private void NextCard()
    {
        if (currentCardIndex < categories.Count - 1)
        {
            currentCardIndex++;
        }
    }

    private void HandleTouchStart(TouchEventArgs e)
    {
        if (e.Touches.Length > 0)
        {
            touchStartX = e.Touches[0].ClientX;
            touchStartY = e.Touches[0].ClientY;
            touchCurrentX = touchStartX;
            swipeOffsetPx = 0;
            isSwiping = false;
            swipeDirectionDetermined = false;
        }
    }

    private void HandleTouchMove(TouchEventArgs e)
    {
        if (e.Touches.Length > 0)
        {
            var currentX = e.Touches[0].ClientX;
            var currentY = e.Touches[0].ClientY;

            if (!swipeDirectionDetermined)
            {
                var deltaX = Math.Abs(currentX - touchStartX);
                var deltaY = Math.Abs(currentY - touchStartY);
                
                // Need at least 10px movement to determine direction
                if (deltaX > 10 || deltaY > 10)
                {
                    swipeDirectionDetermined = true;
                    isSwiping = deltaX > deltaY; // Horizontal swipe wins
                }
            }

            if (isSwiping)
            {
                touchCurrentX = currentX;
                swipeOffsetPx = touchCurrentX - touchStartX;

                // Resist swiping past boundaries
                if ((currentCardIndex == 0 && swipeOffsetPx > 0) ||
                    (currentCardIndex == categories.Count - 1 && swipeOffsetPx < 0))
                {
                    swipeOffsetPx *= 0.3; // Rubber band effect
                }

                StateHasChanged();
            }
        }
    }

    private void HandleTouchEnd(TouchEventArgs e)
    {
        if (isSwiping)
        {
            var threshold = 50; // Minimum swipe distance in px
            if (swipeOffsetPx < -threshold && currentCardIndex < categories.Count - 1)
            {
                currentCardIndex++;
            }
            else if (swipeOffsetPx > threshold && currentCardIndex > 0)
            {
                currentCardIndex--;
            }
        }

        swipeOffsetPx = 0;
        isSwiping = false;
        swipeDirectionDetermined = false;
        StateHasChanged();
    }

    private RenderFragment RenderCard(AdvancedCategory category, List<RankedEntry> ranked) => __builder =>
    {
        <div class="border border-wfbc-blue-2 rounded-lg bg-wfbc-white-1 overflow-hidden shadow-sm flex flex-col">
            <!-- Card header -->
            <div class="px-3 py-2 bg-wfbc-grey-1 border-b border-wfbc-grey-2 flex items-center justify-between">
                <div>
                    <h3 class="text-sm sm:text-base font-semibold text-wfbc-blue-2 leading-tight">@category.Name</h3>
                    <p class="text-[10px] sm:text-xs text-gray-500">@category.Subtitle</p>
                </div>
                <div class="text-[10px] sm:text-xs text-gray-500 text-right whitespace-nowrap ml-2">
                    Lg Avg<br />
                    <span class="font-mono font-semibold text-wfbc-blue-2">@((category.LeagueAvgFormatter ?? category.Formatter)(category.LeagueAvgAccessor(Standings)))</span>
                </div>
            </div>
            <!-- Card body / leaderboard rows -->
            <div class="divide-y divide-wfbc-grey-1">
                @for (int i = 0; i < ranked.Count; i++)
                {
                    var entry = ranked[i];
                    var rank = i + 1;
                    var rankClass = GetRankRowClass(rank);
                    <div class="flex items-center justify-between px-3 py-2 text-sm @rankClass">
                        <div class="flex items-center gap-2 min-w-0">
                            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-wfbc-blue-1 text-wfbc-white-1 text-xs font-semibold flex-shrink-0">@rank</span>
                            <div class="min-w-0">
                                <div class="font-medium text-wfbc-blue-2 truncate">@entry.Standing.TeamName</div>
                                <div class="text-[10px] sm:text-xs text-gray-500 truncate">@entry.Standing.Manager</div>
                            </div>
                        </div>
                        <div class="font-mono text-wfbc-blue-2 font-semibold tabular-nums flex-shrink-0 ml-2">
                            @category.Formatter(entry.Value)
                        </div>
                    </div>
                }
            </div>
        </div>
    };

    private record AdvancedCategory(
        string Name,
        string Subtitle,
        Func<Standings, decimal> Accessor,
        Func<decimal, string> Formatter,
        bool LowerIsBetter,
        Func<List<Standings>, decimal> LeagueAvgAccessor,
        Func<decimal, string>? LeagueAvgFormatter = null);

    private record RankedEntry(Standings Standing, decimal Value);

    // Declarative list of advanced categories. Add a new entry here to add another
    // leaderboard card. Keep in sync with AdvancedStats fields populated on the server.
    private readonly List<AdvancedCategory> categories = new()
    {
        new AdvancedCategory(
            "Starts",
            "GS (Pitching)",
            s => s.Advanced?.Starts ?? 0m,
            v => ((int)Math.Round(v)).ToString(),
            false,
            all => all.Count == 0 ? 0m : (decimal)all.Sum(s => s.Advanced?.Starts ?? 0) / all.Count,
            v => v.ToString("F1")),
        new AdvancedCategory(
            "Quality Start %",
            "QS / GS",
            s => s.Advanced?.QualityStartRate ?? 0m,
            v => v.ToString("P1"),
            false,
            all => {
                var totalGS = all.Sum(s => s.Advanced?.Starts ?? 0);
                return totalGS == 0 ? 0m : (decimal)all.Sum(s => s.Advanced?.QualityStarts ?? 0) / totalGS;
            }),
        new AdvancedCategory(
            "Strikeout %",
            "K / PA (Batting)",
            s => s.Advanced?.StrikeoutRateBatting ?? 0m,
            v => v.ToString("P1"),
            true,
            all => {
                var totalPA = all.Sum(s => s.Advanced?.BattingPlateAppearances ?? 0);
                return totalPA == 0 ? 0m : (decimal)all.Sum(s => s.Advanced?.BattingStrikeouts ?? 0) / totalPA;
            }),
        new AdvancedCategory(
            "Walk %",
            "BB / PA (Batting)",
            s => s.Advanced?.WalkRateBatting ?? 0m,
            v => v.ToString("P1"),
            false,
            all => {
                var totalPA = all.Sum(s => s.Advanced?.BattingPlateAppearances ?? 0);
                return totalPA == 0 ? 0m : (decimal)all.Sum(s => s.Advanced?.BattingWalks ?? 0) / totalPA;
            }),
        new AdvancedCategory(
            "Plate Appearances",
            "PA (Batting)",
            s => s.Advanced?.BattingPlateAppearances ?? 0m,
            v => ((int)Math.Round(v)).ToString("N0"),
            false,
            all => all.Count == 0 ? 0m : (decimal)all.Sum(s => s.Advanced?.BattingPlateAppearances ?? 0) / all.Count,
            v => v.ToString("F1")),
        new AdvancedCategory(
            "SB Success %",
            "SB / (SB + CS)",
            s => s.Advanced?.StolenBaseSuccessRate ?? 0m,
            v => v.ToString("P1"),
            false,
            all => {
                var totalSB = all.Sum(s => s.Advanced?.BattingStolenBases ?? 0);
                var totalCS = all.Sum(s => s.Advanced?.BattingCaughtStealing ?? 0);
                return (totalSB + totalCS) == 0 ? 0m : (decimal)totalSB / (totalSB + totalCS);
            }),
        new AdvancedCategory(
            "BABIP",
            "(H-HR) / (AB-K-HR+SF)",
            s => s.Advanced?.BABIP ?? 0m,
            v => v.ToString("F3"),
            false,
            all => {
                var totalH = all.Sum(s => s.Advanced?.BattingHits ?? 0);
                var totalHR = all.Sum(s => s.Advanced?.BattingHomeRuns ?? 0);
                var totalAB = all.Sum(s => s.Advanced?.BattingAtBats ?? 0);
                var totalK = all.Sum(s => s.Advanced?.BattingStrikeouts ?? 0);
                var totalSF = all.Sum(s => s.Advanced?.BattingSacrificeFlies ?? 0);
                var denom = totalAB - totalK - totalHR + totalSF;
                return denom == 0 ? 0m : (decimal)(totalH - totalHR) / denom;
            }),
    };

    private List<RankedEntry> RankForCategory(AdvancedCategory category)
    {
        if (Standings == null || Standings.Count == 0)
        {
            return new List<RankedEntry>();
        }

        var entries = Standings
            .Select(s => new RankedEntry(s, category.Accessor(s)))
            .ToList();

        return category.LowerIsBetter
            ? entries.OrderBy(e => e.Value).ThenBy(e => e.Standing.TeamName).ToList()
            : entries.OrderByDescending(e => e.Value).ThenBy(e => e.Standing.TeamName).ToList();
    }

    private static string GetRankRowClass(int rank) => rank switch
    {
        1 => "bg-yellow-50",
        2 => "bg-gray-50",
        3 => "bg-orange-50",
        _ => ""
    };
}